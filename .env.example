# Database configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=theveryl_theverylittlewar

# Admin password hash (bcrypt)
# Generate with: php -r "echo password_hash('your-password', PASSWORD_DEFAULT);"
ADMIN_PASSWORD_HASH=

# Admin alert email for critical multi-account detections
ADMIN_ALERT_EMAIL=theverylittlewar@gmail.com

# Secret salt used by logger (IP hashing) and rate limiter (key derivation).
# Generate with: php -r "echo bin2hex(random_bytes(16));"
SECRET_SALT=replace_with_random_32char_hex_string
