# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    # X-Frame-Options and X-XSS-Protection are set in includes/layout.php via PHP header()
    # to avoid duplicate headers with conflicting values (layout.php sets DENY and 0 respectively)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # CSP is now set via PHP header() in includes/layout.php with per-request nonces
    # See includes/csp.php for nonce generation
</IfModule>

# Disable directory listing
Options -Indexes

# Deny access to sensitive files, editor backups, and executables (P5-GAP-035, INFRA-P8-001)
<FilesMatch "\.(sql|psd|md|json|xml|lock|gitignore|bak|swp|swo|orig|env|phar|pem|key|crt)$|~$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Deny access to hidden files and directories
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# PHP settings for security
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag log_errors on
    php_value error_reporting 32767
    php_flag expose_php off
</IfModule>
